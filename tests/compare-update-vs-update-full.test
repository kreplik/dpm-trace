# Verbose update-vs-update output via --full: original section-based layout.
# RUN: env PYTHONPATH=%root/src %python -m dpm_trace.cli compare %root/tests/fixtures/compare/trace-a.json %root/tests/fixtures/compare/trace-b.json --color never --full | FileCheck %s

# CHECK: DPM trace comparison
# CHECK: kind:   update-vs-update
# CHECK: visible differences found
# CHECK: baseline:{{.*}}update-fixture-trace-a-0001
# CHECK: candidate:{{.*}}update-fixture-trace-b-0002
# CHECK: Event counts
# CHECK: Root events
# CHECK: Counter:Counter
# CHECK: Token:Token
